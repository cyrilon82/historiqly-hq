---
const year = new Date().getFullYear();

const footerLinks = [
  { label: "Contact", href: "mailto:hello@historiqly.com" },
  { label: "About", href: "https://historiqly.com/about" },
  { label: "Privacy", href: "https://historiqly.com/privacy" },
];
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-left">
      <span class="footer-brand">Histor<span class="footer-iq">IQ</span>ly</span>
      <span class="footer-copy">&copy; {year} &middot; AI-curated content</span>
    </p>
    <nav class="footer-links">
      {footerLinks.map((link, i) => (
        <>
          <a href={link.href} class="footer-link">{link.label}</a>
          {i < footerLinks.length - 1 && (
            <svg class="footer-glyph" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" />
            </svg>
          )}
        </>
      ))}
    </nav>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    margin-top: auto;
    border-top: 1px solid rgba(227, 171, 113, 0.08);
    padding: 0.6rem 1.5rem;
    background: transparent;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
  }

  .footer-brand {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--foreground);
    letter-spacing: -0.01em;
    opacity: 0.6;
  }

  .footer-iq {
    background: linear-gradient(180deg, #f3e3c6 0%, #e3ab71 55%, #b97a37 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .footer-copy {
    font-size: 0.65rem;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .footer-link {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--gold);
  }

  .footer-glyph {
    width: 4px;
    height: 4px;
    color: rgba(227, 171, 113, 0.2);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 0.5rem 1rem;
    }

    .footer-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.25rem;
    }

    .footer-left {
      gap: 0.4rem;
    }

    .footer-brand {
      font-size: 0.8rem;
    }

    .footer-copy {
      font-size: 0.55rem;
    }

    .footer-link {
      font-size: 0.55rem;
    }

    .footer-glyph {
      width: 3px;
      height: 3px;
    }
  }
</style>
