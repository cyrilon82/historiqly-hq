---
const links = [
  { label: "Chat", href: "https://app.historiqly.com" },
  { label: "Blog", href: "https://blog.historiqly.com" },
  { label: "Chronicles", href: "https://chronicles.historiqly.com" },
  { label: "Books", href: "https://books.historiqly.com" },
];
---

<header class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <span class="brand-name">Histor<span class="brand-iq">IQ</span>ly</span>
    </a>

    <!-- Ornamental separator -->
    <span class="nav-sep" aria-hidden="true">
      <svg viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 2L9.5 6.5L14 8L9.5 9.5L8 14L6.5 9.5L2 8L6.5 6.5Z" />
      </svg>
    </span>

    <nav class="nav-links" id="navLinks">
      {links.map((link, i) => (
        <>
          <a href={link.href} class="nav-link" target="_blank" rel="noopener">
            {link.label}
          </a>
          {i < links.length - 1 && (
            <span class="link-dot" aria-hidden="true"></span>
          )}
        </>
      ))}
    </nav>

    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

</header>

<script>
  const toggle = document.getElementById('navToggle');
  const links = document.getElementById('navLinks');

  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('open');
    links?.classList.toggle('open');
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: rgba(15, 12, 8, 0.6);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(227, 171, 113, 0.08);
    z-index: 100;
  }


  .nav-inner {
    max-width: 1200px;
    height: 100%;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-brand {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .brand-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--foreground);
    letter-spacing: -0.01em;
  }

  .brand-iq {
    background: linear-gradient(180deg, #f3e3c6 0%, #e3ab71 55%, #b97a37 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Star glyph separator between brand and links */
  .nav-sep {
    display: flex;
    align-items: center;
    margin: 0 1.25rem;
  }

  .nav-sep svg {
    width: 8px;
    height: 8px;
    color: rgba(227, 171, 113, 0.3);
    animation: slow-rotate 20s linear infinite;
  }

  @keyframes slow-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: auto;
  }

  /* Small gold dot between links */
  .link-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(227, 171, 113, 0.25);
    margin: 0 1rem;
    flex-shrink: 0;
  }

  .nav-link {
    color: var(--muted-foreground);
    text-decoration: none;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    position: relative;
  }

  .nav-link:hover {
    color: var(--gold-light);
    border-bottom-color: var(--gold);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--gold);
    transition: all 0.3s;
    border-radius: 1px;
  }

  .nav-toggle.open span:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .nav-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.open span:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  @media (max-width: 768px) {
    .nav-sep {
      display: none;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 56px;
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(15, 12, 8, 0.95);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      padding: 1.25rem 1.5rem;
      gap: 0;
      border-bottom: 1px solid rgba(227, 171, 113, 0.12);
    }

    .nav {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(15, 12, 8, 0.88);
    }

    .nav-links.open {
      display: flex;
    }

    .link-dot {
      display: none;
    }

    .nav-link {
      font-size: 0.85rem;
      padding: 0.6rem 0;
      border-bottom: none;
      width: 100%;
      text-align: center;
    }

    .nav-link:hover {
      border-bottom: none;
      color: var(--gold);
    }

    .nav-toggle {
      display: flex;
    }
  }
</style>
